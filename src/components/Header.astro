---
import type { links as LinksType } from '../data/site';

interface Props {
  handle: string;
  since:  string;
  status: string;
  bio:    string;
  links:  typeof LinksType;
}

const { handle, since, status, bio, links } = Astro.props;

// SVG icon map
const icons: Record<string, string> = {
  github: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>`,
  substack: `<path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>`,
  x: `<path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>`,
  target: `<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm0-14a6 6 0 1 0 6 6 6 6 0 0 0-6-6zm0 10a4 4 0 1 1 4-4 4 4 0 0 1-4 4zm0-6a2 2 0 1 0 2 2 2 2 0 0 0-2-2z"/>`,
};
---

<header>
  <!-- Topbar -->
  <div class="flex items-center justify-between py-6 border-b border-border">
    <span class="font-condensed text-[0.72rem] font-semibold tracking-[0.2em] uppercase text-dim">
      {handle}
    </span>
    <div class="flex items-center gap-2 font-mono text-[0.65rem] text-dim tracking-wide">
      <div class="status-dot"></div>
      {status}
    </div>
  </div>

  <!-- Hero -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 py-16 md:py-20 border-b border-border items-end">
    <!-- Name -->
    <div>
      <h1 class="font-condensed font-semibold uppercase leading-[0.95] tracking-[-0.01em] text-ink"
          style="font-size: clamp(3rem, 7vw, 5.5rem);">
        {handle.replace('menace', '')}
        <br />
        <span class="text-dim font-medium">menace</span>
      </h1>
    </div>

    <!-- Bio + links -->
    <div class="pb-1">
      <p class="text-[0.9rem] leading-[1.85] text-mid font-light mb-8 whitespace-pre-line">
        {bio}
      </p>

      <nav class="flex flex-wrap gap-1">
        {links.map((link) => (
          link.icon === 'flag-ua' ? (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-[0.35rem] font-mono text-[0.68rem] tracking-[0.04em] text-dim border border-border px-[0.7rem] py-[0.3rem] mr-1 mb-1 transition-all duration-150 hover:text-ink hover:border-ink hover:bg-bg2"
            >
              <svg viewBox="0 0 24 16" width="18" height="12" xmlns="http://www.w3.org/2000/svg" style="border: 1px solid #e0e0e0; flex-shrink:0;">
                <rect width="24" height="8" fill="#005BBB"/>
                <rect y="8" width="24" height="8" fill="#FFD500"/>
              </svg>
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-[0.35rem] font-mono text-[0.68rem] tracking-[0.04em] text-dim border border-border px-[0.7rem] py-[0.3rem] mr-1 mb-1 transition-all duration-150 hover:text-ink hover:border-ink hover:bg-bg2"
            >
              <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" style="flex-shrink:0;" set:html={icons[link.icon] ?? ''} />
              {link.label}
            </a>
          )
        ))}
      </nav>
    </div>
  </div>
</header>
